# -------------------------
# AWS Ubuntu 22.04 (extracted kernel/initrd under /aws-ubuntu2204/boot)
# NOTE:
# 你這個 tar.gz 不一定是 casper/ISO 流程能直接用；但你要求 vmlinuz/initrd 走解壓後路徑，這裡已完成。
# -------------------------
menuentry 'AWS Ubuntu 22.04 IPv4 (VGA/Normal)' {
    linux  (http,192.168.1.1)/aws-ubuntu2204/boot/vmlinuz ip=dhcp ---
    initrd (http,192.168.1.1)/aws-ubuntu2204/boot/initrd.img
}
menuentry 'AWS Ubuntu 22.04 IPv4 (SOL)' {
    linux  (http,192.168.1.1)/aws-ubuntu2204/boot/vmlinuz ip=dhcp ${sol_console} ---
    initrd (http,192.168.1.1)/aws-ubuntu2204/boot/initrd.img
}
